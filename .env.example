# Admin Dashboard - Environment variables
# Copy to .env.local and fill in your values

# API URLs (optional - overrides when set, e.g. for local backend)
# VITE_CONTENT_API_DEV=https://dev-api-music-iota.vercel.app
# VITE_CONTENT_API_PROD=https://api-music-iota.vercel.app
# VITE_COURSES_API_DEV=https://dev-api-music-iota.vercel.app
# VITE_COURSES_API_PROD=https://api-music-iota.vercel.app
# VITE_NOTIFICATIONS_API=https://breathing-ejercices-api.vercel.app
# Optional admin key for protected /admin/membership-audit endpoint
# VITE_ADMIN_DASHBOARD_API_KEY=your_admin_dashboard_api_key
# Optional override base URL only for membership audit report endpoint
# VITE_MEMBERSHIP_AUDIT_API_URL=https://your-ngrok-url.ngrok-free.app

# Google AI (Gemini) for mantra title/description suggestions
# VITE_GOOGLE_AI_API_KEY=your_google_ai_api_key
# VITE_GOOGLE_AI_MODEL=gemini-2.5-flash

# Gmail AI dashboard (Supabase + webhook)
# VITE_GMAIL_SUPABASE_URL=https://your-project.supabase.co
# VITE_GMAIL_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: fallback keys used by the Gmail page as well
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional webhook override for "Send Reply"
# VITE_GMAIL_REPLY_WEBHOOK_URL=https://your-webhook-endpoint
