            {
              "id": "a08f1bb1-f7f0-4db5-8602-1d25b0ec0f4f",
              "name": "draft_reply",
              "value": "={{ (() => { const payload = $json.body || $json; const data = payload.data || []; const assistant = data.find((m) => m.role === 'assistant'); if (!assistant) return ''; const parts = assistant.content || []; const lines = []; for (const part of parts) { if (part?.type === 'text' && part?.text?.value) lines.push(part.text.value); else if (part?.text && typeof part.text === 'string') lines.push(part.text); else if (part?.type === 'output_text' && part?.text) lines.push(part.text); else if (part?.type === 'refusal' && part?.refusal) lines.push(part.refusal); } const raw = lines.join('\\n').trim(); if (!raw) return ''; const parseAnswer = (text) => { try { const obj = JSON.parse(text); if (obj && typeof obj === 'object' && typeof obj.answer === 'string') return obj.answer.trim(); } catch {} const fence = text.match(/```(?:json)?\\s*([\\s\\S]*?)```/i); if (fence?.[1]) { try { const obj = JSON.parse(fence[1].trim()); if (obj && typeof obj === 'object' && typeof obj.answer === 'string') return obj.answer.trim(); } catch {} } return ''; }; const fromJson = parseAnswer(raw); if (fromJson) return fromJson; const lower = raw.toLowerCase(); if (lower.includes('sources') && lower.includes('keys exactly: answer, shortcuts')) return ''; return raw; })() }}",
              "type": "string"
            },
            {
              "id": "5eef6ad6-f9c4-4ca3-94ca-ae5190a3799c",
              "name": "debug_message_count",
              "value": "={{ (($json.body || $json).data || []).length }}",
              "type": "number"
            }
